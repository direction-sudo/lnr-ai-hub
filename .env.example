# ─────────────────────────────────────────────────────────────────
# LNR AI Hub — Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── Kimi API (Required for AI responses) ────────────────────────
KIMI_API_KEY=               # Your Moonshot/Kimi API key (sk-...)
KIMI_OPEN_URL=https://api.moonshot.ai

# ── Kimi OAuth (Optional — for user authentication) ─────────────
APP_ID=                     # Kimi OAuth App ID
APP_SECRET=                 # Kimi OAuth App Secret
KIMI_AUTH_URL=              # Kimi OAuth server URL
VITE_KIMI_AUTH_URL=         # Same as KIMI_AUTH_URL (for frontend)
VITE_APP_ID=                # Same as APP_ID (for frontend)

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=sqlite:./data/lnr-ai-hub.db

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=             # Union ID of the admin user

# ── IFTTT (Optional — for social media auto-publishing) ─────────
IFTTT_WEBHOOK_KEY=          # Your IFTTT Webhooks key
